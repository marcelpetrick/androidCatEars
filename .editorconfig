root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# Composable functions follow PascalCase by convention — suppress ktlint's camelCase rule for them
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.xml]
indent_size = 4

[*.toml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
