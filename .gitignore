# -------------------------------------------------------
# Android / Gradle build outputs  (all regenerable)
# -------------------------------------------------------
build/
.gradle/
out/

# Android Studio captures
captures/

# Generated source
generated/

# Local machine configuration  (never committed)
local.properties

# Keystore / signing artefacts  (secrets must not be stored in git)
*.jks
*.keystore

# Android build artefacts
*.apk
*.aab
*.ap_
*.dex

# Lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Coverage reports  (regenerated by Kover / JaCoCo)
**/build/reports/

# -------------------------------------------------------
# IDE — IntelliJ IDEA / Android Studio
# -------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws

# -------------------------------------------------------
# OS artefacts
# -------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~

# -------------------------------------------------------
# The Gradle *wrapper* jars ARE committed so the build is
# self-contained (no global Gradle required).
# Everything else under gradle/ that is generated is not.
# -------------------------------------------------------
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
