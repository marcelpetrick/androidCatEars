#
# Template for release signing credentials.
#
# Copy this file to `keystore.properties` (which is gitignored) and fill in the
# real values, OR provide the same values via environment variables:
#   RELEASE_STORE_FILE, RELEASE_STORE_PASSWORD, RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD
#
# Never commit the real keystore.properties or the .jks/.keystore file.
#
# Create a keystore with:
#   keytool -genkeypair -v -keystore release.jks -alias catears \
#     -keyalg RSA -keysize 2048 -validity 10000

# Path to the keystore file (absolute, or relative to the :app module dir).
storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=catears
keyPassword=CHANGE_ME
